{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "rootDir": ".",
        "noEmit": true,
        "paths": {
            "@graphql2mcp/core": ["./packages/core/src/index.ts"],
            "graphql2mcp": ["./packages/proxy/src/index.ts"],
            "@graphql2mcp/lib": ["./packages/lib/src/index.ts"]
        }
    },
    "include": [
        "packages/*/src",
        "packages/*/test",
        "packages/*/*.config.ts",
        "examples/*/src",
        "examples/*/test",
        "examples/*/*.config.ts",
        "*.config.ts",
        "docs/.vitepress/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "**/dist",
        "**/node_modules",
        "**/coverage",
        "**/test/integration/bun.test.ts",
        "**/test/integration/deno.test.ts",
        "**/test/integration/node.test.mts"
    ]
}
