{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "rootDir": ".",
        "noEmit": true
    },
    "include": [
        "packages/core/src",
        "packages/core/test",
        "packages/core/*.config.ts",
        "packages/proxy/src",
        "packages/proxy/test",
        "packages/proxy/*.config.ts",
        "packages/lib/src",
        "packages/lib/test",
        "packages/lib/*.config.ts",
        "*.config.ts",
        "docs/.vitepress/**/*.ts"
    ],
    "exclude": ["node_modules", "**/dist", "**/node_modules"]
}
