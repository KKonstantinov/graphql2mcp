{
    "name": "@graphql-to-mcp/core",
    "version": "0.0.0",
    "description": "Shared conversion engine: GraphQL schemas to MCP tool definitions",
    "type": "module",
    "sideEffects": false,
    "engines": {
        "node": ">=24"
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:integration:node": "node --test test/integration/node.test.mts",
        "test:integration:bun": "bun test test/integration/bun.test.ts",
        "test:integration:deno": "deno test --no-check --allow-read --allow-env test/integration/deno.test.ts",
        "test:integration": "pnpm run build && pnpm run test:integration:node",
        "typecheck": "tsgo --noEmit",
        "release:jsr": "npx jsr publish --allow-dirty"
    },
    "dependencies": {
        "graphql": "^16.13.1",
        "zod": "^4.3.6"
    },
    "keywords": [
        "graphql",
        "mcp",
        "model-context-protocol",
        "schema",
        "converter",
        "deno",
        "bun"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/KKonstantinov/graphql-to-mcp.git",
        "directory": "packages/core"
    },
    "homepage": "https://github.com/KKonstantinov/graphql-to-mcp/tree/main/packages/core#readme",
    "bugs": {
        "url": "https://github.com/KKonstantinov/graphql-to-mcp/issues"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "license": "MIT"
}
