{
    "name": "@graphql2mcp/lib",
    "version": "0.0.0",
    "description": "Library for integrating GraphQL-to-MCP conversion into existing TypeScript MCP servers",
    "type": "module",
    "sideEffects": false,
    "engines": {
        "node": ">=24"
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:integration": "vitest run test/integration",
        "typecheck": "tsgo --noEmit",
        "release:jsr": "npx jsr publish --allow-dirty"
    },
    "dependencies": {
        "@graphql2mcp/core": "workspace:*",
        "graphql": "^16.13.1",
        "zod": "^4.3.6"
    },
    "keywords": [
        "graphql",
        "mcp",
        "model-context-protocol",
        "library",
        "typescript",
        "ai",
        "agent"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/KKonstantinov/graphql2mcp.git",
        "directory": "packages/lib"
    },
    "homepage": "https://github.com/KKonstantinov/graphql2mcp/tree/main/packages/lib#readme",
    "bugs": {
        "url": "https://github.com/KKonstantinov/graphql2mcp/issues"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "license": "MIT",
    "devDependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1"
    },
    "peerDependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1"
    }
}
